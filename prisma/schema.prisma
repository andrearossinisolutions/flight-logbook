generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum MovementType {
  TOPUP
  FLIGHT
  SERVICE
  REMINDER
}

enum FlightInputMode {
  HOBBS
  MANUAL
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  fullName     String?
  settings     Settings?
  movements             Movement[]
  partnerships          PartnershipMember[]
  partnershipTransactns PartnershipTransaction[]
  partnershipMessages   PartnershipMessage[]
  rentalAircrafts       RentalAircraft[]
  resetToken          String?    @unique
  resetTokenExpiresAt DateTime?
  createdAt             DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Settings {
  id                    String   @id @default(cuid())
  userId                String   @unique
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rentalRatePerHour     Decimal  @default(150)
  instructorRatePerHour Decimal  @default(80)
  currency              String   @default("EUR")
  defaultBase           String?
  dateMonoExam          DateTime?
  dateMedicalExam       DateTime?
  dateBipoExam          DateTime?
  dateFoniaExam         DateTime?
  dateAdvanced          DateTime?
  onboardingCompleted   Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model Movement {
  id        String       @id @default(cuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      MovementType
  date      DateTime
  amount    Decimal
  notes     String?
  flight    Flight?
  isDraft   Boolean
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([userId, date])
}

model Flight {
  id                    String          @id @default(cuid())
  movementId            String          @unique
  movement              Movement        @relation(fields: [movementId], references: [id], onDelete: Cascade)

  partnershipAircraftId String?
  partnershipAircraft   PartnershipAircraft? @relation(fields: [partnershipAircraftId], references: [id], onDelete: SetNull)

  aircraft              String          @default("P92") // legacy field, non più usato dal codice
  aircraftRegistration  String          @default("I-4150")
  aircraftType          String          @default("P92")

  inputMode             FlightInputMode
  hobbsStartMinutes     Int?
  hobbsEndMinutes       Int?
  durationMinutes       Int
  passengerName         String?
  instructorName        String?
  instructorMinutes     Int

  takeoffPlace          String?
  arrivalPlace          String?
  engineOn              DateTime?
  engineOff             DateTime?

  rentalRateApplied     Decimal
  instructorRateApplied Decimal
  rentalCost            Decimal
  instructorCost        Decimal
  totalCost             Decimal

  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
}

model DailyJobState {
  key            String   @id
  lastRunDateKey String?
  lastRunAt      DateTime?
  
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model PartnershipMessage {
  id             String      @id @default(cuid())
  content        String
  partnershipId  String
  partnership    Partnership @relation(fields: [partnershipId], references: [id], onDelete: Cascade)
  userId         String
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model Partnership {
  id          String   @id @default(cuid())
  name        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members      PartnershipMember[]
  aircrafts    PartnershipAircraft[]
  fixedCosts   PartnershipFixedCost[]
  transactions PartnershipTransaction[]
  invitations  PartnershipInvitation[]
  messages     PartnershipMessage[]
}

model PartnershipMember {
  id             String      @id @default(cuid())
  partnershipId  String
  partnership    Partnership @relation(fields: [partnershipId], references: [id], onDelete: Cascade)
  userId         String
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           String      @default("MEMBER") // ADMIN or MEMBER
  
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@unique([partnershipId, userId])
}

model PartnershipAircraft {
  id               String      @id @default(cuid())
  partnershipId    String
  partnership      Partnership @relation(fields: [partnershipId], references: [id], onDelete: Cascade)
  registration     String      @unique
  type             String
  
  hourlyFuelCost   Decimal     @default(0)
  hourlyMaintCost  Decimal     @default(0)
  hourlyEngineFund Decimal     @default(0)
  initialHours     Decimal     @default(0)

  flights          Flight[]
  reminders        PartnershipAircraftReminder[]
  maintenanceLogs  PartnershipAircraftMaintenanceLog[]

  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
}

model PartnershipAircraftReminder {
  id                 String              @id @default(cuid())
  aircraftId         String
  aircraft           PartnershipAircraft @relation(fields: [aircraftId], references: [id], onDelete: Cascade)
  description        String
  hoursInterval      Decimal
  lastCompletedHours Decimal             @default(0)
  
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([aircraftId])
}

model PartnershipAircraftMaintenanceLog {
  id               String              @id @default(cuid())
  aircraftId       String
  aircraft         PartnershipAircraft @relation(fields: [aircraftId], references: [id], onDelete: Cascade)
  description      String
  performedAtHours Decimal
  date             DateTime            @default(now())
  notes            String?
  
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@index([aircraftId])
}

model PartnershipFixedCost {
  id             String      @id @default(cuid())
  partnershipId  String
  partnership    Partnership @relation(fields: [partnershipId], references: [id], onDelete: Cascade)
  description    String
  amount         Decimal
  period         String      @default("MONTHLY")
  billingMonth   Int?
  
  billingYear    Int?
  
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model PartnershipTransaction {
  id             String      @id @default(cuid())
  partnershipId  String
  partnership    Partnership @relation(fields: [partnershipId], references: [id], onDelete: Cascade)
  userId         String?
  user           User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  amount         Decimal
  type           String      // "INCOME" (versamento soci) o "EXPENSE" (spese società)
  description    String
  date           DateTime    @default(now())
  
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model RentalAircraft {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  registration String
  type         String   @default("P92")
  hourlyCost   Decimal  @default(150)
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, registration])
}

model PartnershipInvitation {
  id            String      @id @default(cuid())
  partnershipId String
  partnership   Partnership @relation(fields: [partnershipId], references: [id], onDelete: Cascade)
  email         String
  role          String      @default("MEMBER")
  expiresAt     DateTime
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([partnershipId, email])
}
