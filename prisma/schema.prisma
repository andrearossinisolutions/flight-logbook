generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum MovementType {
  TOPUP
  FLIGHT
  SERVICE
}

enum FlightInputMode {
  HOBBS
  MANUAL
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  fullName     String?
  settings     Settings?
  movements    Movement[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Settings {
  id                    String   @id @default(cuid())
  userId                String   @unique
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rentalRatePerHour     Decimal  @default(150)
  instructorRatePerHour Decimal  @default(80)
  currency              String   @default("EUR")
  dateMonoExam          DateTime?
  dateMedicalExam       DateTime?
  dateBipoExam          DateTime?
  dateFoniaExam         DateTime?
  dateAdvanced          DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model Movement {
  id        String       @id @default(cuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      MovementType
  date      DateTime
  amount    Decimal
  notes     String?
  flight    Flight?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([userId, date])
}

model Flight {
  id                    String          @id @default(cuid())
  movementId            String          @unique
  movement              Movement        @relation(fields: [movementId], references: [id], onDelete: Cascade)

  aircraft              String          @default("P92") // legacy field, non più usato dal codice
  aircraftRegistration  String          @default("I-4150")
  aircraftType          String          @default("P92")

  inputMode             FlightInputMode
  hobbsStartMinutes     Int?
  hobbsEndMinutes       Int?
  durationMinutes       Int
  instructorName        String?
  instructorMinutes     Int

  rentalRateApplied     Decimal
  instructorRateApplied Decimal
  rentalCost            Decimal
  instructorCost        Decimal
  totalCost             Decimal

  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
}