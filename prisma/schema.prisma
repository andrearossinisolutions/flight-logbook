generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum MovementType {
  TOPUP
  FLIGHT
  SERVICE
}

enum FlightInputMode {
  HOBBS
  MANUAL
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  fullName     String?
  settings     Settings?
  movements    Movement[]
  partnerships PartnershipMember[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Settings {
  id                    String   @id @default(cuid())
  userId                String   @unique
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rentalRatePerHour     Decimal  @default(150)
  instructorRatePerHour Decimal  @default(80)
  currency              String   @default("EUR")
  defaultBase           String?
  dateMonoExam          DateTime?
  dateMedicalExam       DateTime?
  dateBipoExam          DateTime?
  dateFoniaExam         DateTime?
  dateAdvanced          DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model Movement {
  id        String       @id @default(cuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      MovementType
  date      DateTime
  amount    Decimal
  notes     String?
  flight    Flight?
  isDraft   Boolean
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([userId, date])
}

model Flight {
  id                    String          @id @default(cuid())
  movementId            String          @unique
  movement              Movement        @relation(fields: [movementId], references: [id], onDelete: Cascade)

  partnershipAircraftId String?
  partnershipAircraft   PartnershipAircraft? @relation(fields: [partnershipAircraftId], references: [id], onDelete: SetNull)

  aircraft              String          @default("P92") // legacy field, non più usato dal codice
  aircraftRegistration  String          @default("I-4150")
  aircraftType          String          @default("P92")

  inputMode             FlightInputMode
  hobbsStartMinutes     Int?
  hobbsEndMinutes       Int?
  durationMinutes       Int
  passengerName         String?
  instructorName        String?
  instructorMinutes     Int

  takeoffPlace          String?
  arrivalPlace          String?
  engineOn              DateTime?
  engineOff             DateTime?

  rentalRateApplied     Decimal
  instructorRateApplied Decimal
  rentalCost            Decimal
  instructorCost        Decimal
  totalCost             Decimal

  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
}

model DailyJobState {
  key            String   @id
  lastRunDateKey String?
  lastRunAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Partnership {
  id          String   @id @default(cuid())
  name        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members     PartnershipMember[]
  aircrafts   PartnershipAircraft[]
  fixedCosts  PartnershipFixedCost[]
}

model PartnershipMember {
  id             String      @id @default(cuid())
  partnershipId  String
  partnership    Partnership @relation(fields: [partnershipId], references: [id], onDelete: Cascade)
  userId         String
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           String      @default("MEMBER") // ADMIN or MEMBER
  
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@unique([partnershipId, userId])
}

model PartnershipAircraft {
  id               String      @id @default(cuid())
  partnershipId    String
  partnership      Partnership @relation(fields: [partnershipId], references: [id], onDelete: Cascade)
  registration     String      @unique
  type             String
  
  hourlyFuelCost   Decimal     @default(0)
  hourlyMaintCost  Decimal     @default(0)
  hourlyEngineFund Decimal     @default(0)

  flights          Flight[]

  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
}

model PartnershipFixedCost {
  id             String      @id @default(cuid())
  partnershipId  String
  partnership    Partnership @relation(fields: [partnershipId], references: [id], onDelete: Cascade)
  description    String
  amount         Decimal
  period         String      @default("MONTHLY")
  
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

